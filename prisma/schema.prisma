// recon Prisma schema.
//
// Two halves:
//
//   1. ledger-core models recon QUERIES (LegalEntity, Book, Account,
//      JournalEntry, JournalLine, Party, Currency, Period, FiscalCalendar).
//      These mirror the canonical definitions in ledger-core's schema —
//      column-for-column. recon does NOT migrate these tables; ledger-core
//      owns the schema. If ledger-core's schema changes upstream, this
//      copy MUST be re-synced.
//
//   2. recon-specific models recon OWNS (BankAccount, BankStatement,
//      BankStatementLine, ReconciliationMatch, AiSuggestion). These live
//      only here; `prisma db push` from this repo creates them on top of
//      the existing ledger-core tables.
//
// The two repos share one Postgres database — recon connects with the same
// DATABASE_URL as ledger-core. Per the universal-schema spec: "Postgres
// schema dependency is cleaner than npm-package dependency for this
// domain."

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// ledger-core mirror — DO NOT EDIT without syncing upstream
// =========================================================================

model LegalEntity {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Phase 4b in ledger-core: code is unique per [tenantId, code], not globally.
  // SECURITY (pen-test pass 4): tenantId added so Server Actions can
  // tenant-scope their record lookups. The column exists in the shared
  // DB; declaring it here lets recon's Prisma client filter by it.
  tenantId             String   @db.Uuid
  code                 String
  name                 String
  parentEntityId       String?  @db.Uuid
  functionalCurrencyId String
  sourceSystem         String?
  sourceRecordType     String?
  sourceRecordId       String?
  sourcePayload        Json?
  mappingVersion       String?
  extensions           Json?

  journalEntries JournalEntry[]
  bankAccounts   BankAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_entity")
}

model Book {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String    @unique
  name                String
  basis               BookBasis
  reportingCurrencyId String
  isActive            Boolean   @default(true)
  extensions          Json?

  journalEntries JournalEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("book")
}

model Account {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId         String? @db.Uuid
  code             String
  name             String
  type             AccountType
  normalBalance    NormalBalance
  subtype          String?
  isContra         Boolean @default(false)
  isControlAccount Boolean @default(false)
  isBank           Boolean @default(false)
  parentAccountId  String? @db.Uuid
  bookScope        String[] @default([])
  active           Boolean @default(true)

  lines        JournalLine[]
  bankAccounts BankAccount[]

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, code])
  @@map("account")
}

model Party {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId      String? @db.Uuid
  code          String
  displayName   String
  parentPartyId String? @db.Uuid

  journalLines JournalLine[]

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, code])
  @@map("party")
}

model JournalEntry {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Phase 4b: entryNumber unique per [tenantId, entryNumber] in ledger-core.
  // No tenantId in this mirror; drop @unique, callers use findFirst.
  entryNumber   String
  entityId      String   @db.Uuid
  entity        LegalEntity @relation(fields: [entityId], references: [id])
  bookId        String   @db.Uuid
  book          Book        @relation(fields: [bookId], references: [id])
  periodId      String?  @db.Uuid
  documentDate  DateTime @db.Date
  postingDate   DateTime @db.Date
  memo          String
  currencyId    String
  fxRate        Decimal  @default(1) @db.Decimal(20, 10)
  source        JournalSource @default(MANUAL)
  status        EntryStatus   @default(POSTED)
  reversalOfId  String?  @db.Uuid

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  lines JournalLine[]

  // Backrefs to recon's own tables.
  appliedReconciliationMatches ReconciliationMatch[] @relation("AppliedByReconEntry")

  createdAt DateTime @default(now())
  createdBy String?

  @@index([entityId, bookId, documentDate])
  @@map("gl_entry_header")
}

model JournalLine {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entryId   String @db.Uuid
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo    Int
  accountId String @db.Uuid
  account   Account @relation(fields: [accountId], references: [id])

  partyId        String? @db.Uuid
  party          Party?  @relation(fields: [partyId], references: [id])
  itemId         String? @db.Uuid
  dimensionSetId String? @db.Uuid
  taxCodeId      String?

  debit  Decimal @default(0) @db.Decimal(18, 4)
  credit Decimal @default(0) @db.Decimal(18, 4)

  transactionAmount     Decimal @default(0) @db.Decimal(18, 4)
  transactionCurrencyId String?
  reportingAmount       Decimal @default(0) @db.Decimal(18, 4)
  reportingCurrencyId   String?

  description String?
  extensions  Json?

  // Backref to recon's reconciliation matches.
  reconciliationMatches ReconciliationMatch[] @relation("MatchedJournalLine")

  @@unique([entryId, lineNo])
  @@index([accountId])
  @@map("gl_entry_line")
}

// =========================================================================
// recon-owned models — managed by THIS repo
// =========================================================================

// One BankAccount per Postgres-level bank account that recon reconciles.
// The link to ledger-core is via accountId (must point to an Account
// where isBank=true).
model BankAccount {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId      String  @db.Uuid
  entity        LegalEntity @relation(fields: [entityId], references: [id])
  accountId     String  @db.Uuid
  account       Account     @relation(fields: [accountId], references: [id])

  code          String  @unique  // human-readable, e.g. "CHASE-OPERATING"
  displayName   String
  bankName      String?
  accountNumberLast4 String?
  currencyId    String  @default("USD")
  isActive      Boolean @default(true)

  statements    BankStatement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bank_account")
}

model BankStatement {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankAccountId   String   @db.Uuid
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  // Source metadata
  filename        String
  uploadedAt      DateTime @default(now())
  uploadedBy      String?
  format          String   // e.g. "CHASE_CSV_V1", "BOFA_OFX", "GENERIC_CSV"
  rawPayload      String   // verbatim file content for audit / re-parse

  // Statement period
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  openingBalance  Decimal  @db.Decimal(18, 4)
  closingBalance  Decimal  @db.Decimal(18, 4)

  lines           BankStatementLine[]

  // Aggregate status for the UI
  totalLines        Int @default(0)
  matchedLines      Int @default(0)
  pendingLines      Int @default(0)

  // ─── Statement-level lock (v1.1) ──────────────────────────────────
  //
  // OPEN       — default; mutations (propose / decide / ignore /
  //              adjustment) are accepted normally
  // RECONCILED — frozen; all mutating actions refuse until an admin
  //              reopens. Set by reconcileStatementAction once 100% of
  //              the lines resolve (matched + ignored + adjustment).
  //
  // reconciledAt + reconciledBy are stamped on the transition.
  // Reopening clears them so a re-locked statement reflects the
  // latest run, not the original.
  status        BankStatementStatus @default(OPEN)
  reconciledAt  DateTime?
  reconciledBy  String? // user email/displayName at reconcile time

  @@index([bankAccountId, periodEnd])
  @@index([bankAccountId, status])
  @@map("bank_statement")
}

enum BankStatementStatus {
  OPEN
  RECONCILED
}

model BankStatementLine {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  statementId   String @db.Uuid
  statement     BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  lineNo        Int    // 1-based order within the statement
  transactionDate DateTime @db.Date
  postedDate      DateTime? @db.Date
  description     String
  // Signed: positive = deposit / inflow, negative = withdrawal / outflow.
  // Storing signed keeps the SUM(lines) = closingBalance - openingBalance
  // invariant trivial to assert.
  amount        Decimal @db.Decimal(18, 4)
  runningBalance Decimal? @db.Decimal(18, 4)
  externalRef   String?  // bank's own transaction id when available

  status        BankLineStatus @default(UNMATCHED)

  // Audit trail for IGNORED status (v1.0). Populated when a human
  // marks the line IGNORED via ignoreLineAction; preserved across
  // un-ignore so the full history survives. Null for non-IGNORED lines.
  ignoredAt     DateTime?
  ignoredBy     String?
  ignoreReason  String?

  matches       ReconciliationMatch[]
  aiSuggestions AiSuggestion[]

  @@unique([statementId, lineNo])
  @@index([statementId, status])
  @@index([transactionDate])
  @@map("bank_statement_line")
}

enum BankLineStatus {
  UNMATCHED       // no match proposed yet
  PROPOSED        // a match has been suggested (deterministic or AI)
  MATCHED         // human approved the match
  IGNORED         // human marked as not requiring reconciliation
  ADJUSTMENT      // human posted an adjustment JE to resolve the line
}

// Bridges a BankStatementLine to a JournalLine via ledger-core. One bank
// line can match one or more JE lines (e.g. split deposits); one JE line
// can be matched by one bank line (a single deposit clearing).
model ReconciliationMatch {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankLineId        String @db.Uuid
  bankLine          BankStatementLine @relation(fields: [bankLineId], references: [id], onDelete: Cascade)
  journalLineId     String @db.Uuid
  journalLine       JournalLine @relation("MatchedJournalLine", fields: [journalLineId], references: [id])

  // Match source — drives the UI badge color.
  source            MatchSource
  confidence        Decimal? @db.Decimal(5, 4)  // 0.00..1.00 from AI; null for deterministic / manual
  status            MatchStatus @default(PROPOSED)

  // If recon posted an adjustment JE (e.g. for an unbooked bank fee),
  // the resulting ledger-core entry id lives here. The JE itself is
  // posted via ledger-core's postJournalEntry with source="AI_APPROVED"
  // or "MANUAL".
  appliedByEntryId  String? @db.Uuid
  appliedByEntry    JournalEntry? @relation("AppliedByReconEntry", fields: [appliedByEntryId], references: [id])

  approvedAt        DateTime?
  approvedBy        String?
  rejectedAt        DateTime?
  rejectedBy        String?

  createdAt DateTime @default(now())

  @@unique([bankLineId, journalLineId])
  @@index([status])
  @@map("reconciliation_match")
}

enum MatchSource {
  DETERMINISTIC // amount + date + counterparty heuristic
  AI            // proposed by the AI suggester
  MANUAL        // human-drawn link
}

enum MatchStatus {
  PROPOSED
  APPROVED
  REJECTED
  WITHDRAWN
}

// AI proposals are stored separately from ReconciliationMatch so we can
// keep the model's reasoning + confidence even when it's rejected. This
// is the audit trail for "did the AI suggest something useful here?"
model AiSuggestion {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankLineId      String @db.Uuid
  bankLine        BankStatementLine @relation(fields: [bankLineId], references: [id], onDelete: Cascade)

  // SECURITY (pen-test pass 4 follow-up): tenantId stamped on every new
  // row so the audit page can filter without joining through
  // bankLine.statement.bankAccount.entity. Nullable because legacy rows
  // (created before this column was added) don't have a value; the page
  // queries filter null rows out — they're treated as untrusted/legacy.
  // Backfill SQL lives in prisma/backfill-ai-suggestion-tenant.sql.
  tenantId        String? @db.Uuid
  tenant          Tenant? @relation(fields: [tenantId], references: [id])

  // Candidates as a JSON array of { journalLineId, confidence, rationale }
  // in descending confidence order. Stored as JSON because the shape may
  // evolve as the prompt evolves.
  candidatesJson  Json

  modelName       String   // e.g. "claude-haiku-4-5"
  promptHash      String?  // SHA of prompt for cache-hit analytics
  promptTokens    Int?
  completionTokens Int?
  latencyMs       Int?

  createdAt DateTime @default(now())

  @@index([bankLineId])
  @@index([tenantId, createdAt])
  @@map("ai_suggestion")
}

// =========================================================================
// Enums mirrored from ledger-core. MUST stay in sync. These exist in the
// shared DB because ledger-core created them; recon's mirror needs the
// matching type so Prisma db push from this repo doesn't try to alter
// the columns ledger-core owns.
// =========================================================================

enum BookBasis {
  US_GAAP
  US_TAX
  IFRS
  MGMT
  STATUTORY
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalSource {
  MANUAL
  SEED
  SYSTEM
  AI_APPROVED
  IMPORT
}

enum EntryStatus {
  DRAFT
  POSTED
  VOID
  REVERSED
}

// ─── Shared multi-tenancy tables ────────────────────────────────────────
//
// SECURITY (pen-test pass 4): these tables live in the shared DB (owned
// by ledger-core's schema). recon needs read access to them to resolve
// the current Clerk-authenticated user → their TenantMembership → the
// current tenant for Server Action scoping. We declare just enough
// columns to make typed Prisma queries; we never write to them from
// recon. The tables already exist in the DB; no migration needed.

model User {
  id          String  @id @db.Uuid
  email       String  @unique
  displayName String
  isActive    Boolean @default(true)
  memberships TenantMembership[]

  @@map("app_user")
}

model Tenant {
  id                   String             @id @db.Uuid
  slug                 String             @unique
  name                 String
  /// See ledger-core's Tenant.monthlyAiSpendCapUsd. Read-only here;
  /// recon never writes this column.
  monthlyAiSpendCapUsd Decimal?           @db.Decimal(10, 2)
  /// Mirror of ledger-core's Tenant.billingPlan. Read-only.
  /// recon's session.requireRepoAccess() reads this to gate access by plan.
  billingPlan          String?
  /// Mirror of ledger-core's Tenant.subscriptionStatus.
  /// "active" / "trialing" → use billingPlan; everything else falls
  /// back to free tier.
  subscriptionStatus   String?
  memberships          TenantMembership[]
  aiSuggestions        AiSuggestion[]
  rateLimitEvents      RateLimitEvent[]
  aiSpendAlerts        AiSpendAlert[]

  @@map("tenant")
}

/// Spend-threshold alerts. See src/lib/auth/ai-budget.ts. Mirror of
/// fa-amort + revenue-rec's table; recon tracks its own Haiku match
/// spend independently.
model AiSpendAlert {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  /// Source repo — part of the unique constraint so each repo dedupes
  /// its own crossings independently. See fa-amort's schema for the
  /// full rationale.
  source    String
  monthKey  String
  threshold Int
  capUsd    Decimal  @db.Decimal(10, 2)
  spentUsd  Decimal  @db.Decimal(10, 2)
  sentAt    DateTime @default(now())

  @@unique([tenantId, source, monthKey, threshold])
  @@index([tenantId, sentAt])
  @@map("ai_spend_alert")
}

/// Per-action rate-limit ledger. See src/lib/auth/ai-budget.ts.
/// Mirrors fa-amort + revenue-rec; shared concept, per-repo table.
model RateLimitEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?  @db.Uuid
  action    String
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@map("rate_limit_event")
}

model TenantMembership {
  tenantId String     @db.Uuid
  userId   String     @db.Uuid
  /// Mirror of ledger-core's TenantRole enum. Hierarchy:
  /// OWNER > ADMIN > MEMBER > VIEWER. See src/lib/auth/policy.ts
  /// for the permission catalog.
  role     TenantRole @default(MEMBER)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@map("tenant_membership")
}

/// Mirror of ledger-core's TenantRole enum. Must stay in sync —
/// ledger-core's schema is the canonical source. New roles added
/// upstream must be added here too BEFORE the column-type change
/// can land.
enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}
