# Postgres — point this at the SAME database as ledger-core. Recon's
# Prisma schema includes ledger-core's models (read access) + adds its
# own (BankStatement, ReconciliationMatch, etc.). Only ledger-core runs
# `prisma db push` to manage the shared substrate tables; recon's
# `db push` adds its own tables on top.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledger_core?schema=public"

# Anthropic API key for the AI match suggester (added in v0.2). Without
# it, the deterministic scorer in src/lib/matching/deterministic.ts is
# the only match source.
# ANTHROPIC_API_KEY=""
