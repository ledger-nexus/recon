# Postgres — point this at the SAME database as ledger-core. Recon's
# Prisma schema includes ledger-core's models (read access) + adds its
# own (BankStatement, ReconciliationMatch, etc.). Only ledger-core runs
# `prisma db push` to manage the shared substrate tables; recon's
# `db push` adds its own tables on top.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledger_core?schema=public"

# Anthropic API key for the AI match suggester. The Server Action
# `proposeMatchesAction` only calls the API when the deterministic top
# score is below AUTO_PROPOSE_THRESHOLD (0.85). Without this key, the
# deterministic scorer in src/lib/matching/deterministic.ts is the only
# match source and the AI escalation is skipped (logged, non-fatal).
ANTHROPIC_API_KEY=""

# Cross-repo bridge to ledger-core's postJournalEntry. Recon POSTs
# adjustment JEs (created via the "Post adjustment" button on UNMATCHED
# bank lines) to ledger-core's /api/internal/journal-entries endpoint.
# Both repos must share the same token value. See docs/ledger-bridge.md.
LEDGER_CORE_URL="http://localhost:3000"
LEDGER_CORE_INTERNAL_TOKEN=""

# Recon's OWN inbound HTTP boundary. integrations (and any future
# connector that produces bank-feed-like records) POST to
# /api/internal/bank-lines on recon. Token gates the endpoint; set the
# same value in integrations' env. Leaving this unset disables the
# endpoint (returns 503).
RECON_INTERNAL_API_TOKEN=""
