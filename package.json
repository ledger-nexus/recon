    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:ai": "tsx scripts/smoke-test-ai.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@clerk/nextjs": "6.39.4",
    "@prisma/client": "5.22.0",
    "clsx": "2.1.1",
    "decimal.js": "10.6.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.6.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.5.15",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.19",
    "tsx": "4.22.4",
